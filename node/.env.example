# VPN Checker Worker Node Configuration
# Copy this file to .env and adjust values

# REQUIRED: Master panel URL
MASTER_URL=http://192.168.1.100:8000

# REQUIRED: Token from Settings > Node Management in master panel
NODE_TOKEN=your_token_from_master_settings

# Node identification
NODE_NAME=my-standalone-worker
NODE_REGION=Russia

# Optional: Path to sing-box binary (default: /usr/local/bin/sing-box)
# SINGBOX_PATH=/usr/local/bin/sing-box

# Testing parameters
# CONCURRENT_CHECKS=50
# HTTP_TIMEOUT_S=15
# PING_THRESHOLD_MS=1500

# Polling interval (seconds between check-ins to master)
# POLL_INTERVAL_S=60